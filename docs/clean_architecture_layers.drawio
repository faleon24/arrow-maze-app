<mxfile host="app.diagrams.net" version="24.0.0">
  <diagram name="Clean Layers - App" id="app-clean-layers">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="826" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Arrow Maze — App (Flutter) · Clean Architecture — Diagrama de Capas" style="text;html=1;align=center;fontStyle=1;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="40" y="10" width="1080" height="30" as="geometry" />
        </mxCell>

        <mxCell id="capa4" value="&lt;b&gt;CAPA 4 — Frameworks &amp;amp; Drivers&lt;/b&gt; (adapters que envuelven librerías externas)&lt;br&gt;HTTP: AuthHttpAdapter · LevelHttpAdapter · ProgressHttpAdapter · LeaderboardHttpAdapter · ShopHttpAdapter&lt;br&gt;Local (SharedPreferences): SharedPrefsTokenStorage · SharedPrefsWalletAdapter · SharedPrefsInventoryAdapter · SharedPrefsLivesAdapter · DevLevelAdapter&lt;br&gt;Platform: SystemSoundsAudioAdapter · FlutterHapticsAdapter · AudioPlayersMusicAdapter&lt;br&gt;&lt;i&gt;libs externas: Flutter · http · shared_preferences · audioplayers&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECECEC;strokeColor=#616161;strokeWidth=2;verticalAlign=top;align=center;spacingTop=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="50" width="1080" height="720" as="geometry" />
        </mxCell>

        <mxCell id="capa3" value="&lt;b&gt;CAPA 3 — Interface Adapters&lt;/b&gt; (presentación + transporte)&lt;br&gt;Screens: Home · AuthGate · Login · Register · Levels · Game · Leaderboard · Shop · Settings&lt;br&gt;DTOs: LevelDto · AuthResponseDto · LeaderboardEntryDto · MyRankDto · ShopItemDto · i18n: AppLocalizations · LocaleController · Composition root: service_locator (get_it)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5CBCB;strokeColor=#C0392B;strokeWidth=2;verticalAlign=top;align=center;spacingTop=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="95" y="165" width="970" height="600" as="geometry" />
        </mxCell>

        <mxCell id="capa2" value="&lt;b&gt;CAPA 2 — Application / Use Cases&lt;/b&gt; (sin imports de Flutter/http)&lt;br&gt;Use cases: SignIn · Register · SignOut · RestoreSession · GetLevels · GenerateLevel · LoadLevelsCatalog · GetStarsByLevel · SubmitLevelResult · RevealHint · UseGridHighlight · GameFeedback · GetWalletBalance · AwardCoins · GetLives · ConsumeLife · PurchaseLife · ListShopItems · BuyShopItem · GetLeaderboard · GetMyLeaderboardRank · Play/ToggleMusic&lt;br&gt;&lt;b&gt;Puertos: IAuthRepository · IAuthTokenStorage · ILevelRepository · IProgressRepository · ILeaderboardRepository · IShopRepository · IWalletService · IInventoryService · ILivesService · IAudioService · IHapticsService · IMusicService&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F6D9EC;strokeColor=#B03A8C;strokeWidth=2;verticalAlign=top;align=center;spacingTop=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="150" y="270" width="860" height="420" as="geometry" />
        </mxCell>

        <mxCell id="capa1" value="&lt;b&gt;CAPA 1 — Dominio / Entidades&lt;/b&gt;&lt;br&gt;GameSession · Board · ArrowPath · Position · Collectible · TapOutcome · Level · LeaderboardEntry · MyLeaderboardRank · LivesState · UserSession · ShopItem · PowerUpItems&lt;br&gt;«State» GameState (+Playing/Paused/Cleared/Failed) · «Observer» GameObserver&lt;br&gt;«Strategy» Direction (+Up/Down/Left/Right) · «Builder» BoardBuilder · «Factory» DirectionFactory · ArrowColorFactory&lt;br&gt;Servicio de dominio: ArrowRayCalculator&lt;br&gt;&lt;i&gt;clases puras — sin Flutter/http/shared_preferences&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DFF3D8;strokeColor=#2E7D32;strokeWidth=2;verticalAlign=middle;align=center;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="240" y="395" width="680" height="245" as="geometry" />
        </mxCell>

        <mxCell id="deprule" value="Regla de Dependencia: las dependencias apuntan hacia el centro (Capa 4 → 3 → 2 → 1), nunca al revés." style="text;html=1;align=center;fontStyle=1;fontColor=#C0392B;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="300" y="700" width="560" height="20" as="geometry" />
        </mxCell>

